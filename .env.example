# Para os anúncios aparecerem em todos os dispositivos, crie um projeto no Supabase
# e preencha estas variáveis no Vercel em Settings > Environment Variables.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_PUBLIC
VITE_SUPABASE_TABLE=anuncios

# Login do painel admin (/admin)
VITE_ADMIN_EMAIL=admin@casalar.com
VITE_ADMIN_PASSWORD=troque-essa-senha
